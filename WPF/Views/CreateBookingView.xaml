<Window x:Class="WPF.CreateBookingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="CreateBookingView" Height="450" Width="800">
    <Grid>
        <Label Content="Opret Booking&#xD;&#xA;" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="33" Width="127"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,130,0,0" VerticalAlignment="Top">

            <DatePicker DisplayDateStart="{Binding MinDate, Mode=OneTime}" 
            DisplayDateEnd="{Binding MaxDate, Mode=OneTime}" 
            SelectedDate="{Binding Date, UpdateSourceTrigger=PropertyChanged}" 
            Margin="0,0,15,0"/>

            <ComboBox ItemsSource="{Binding TimeSlots}" 
                      SelectedItem="{Binding StartTime}" 
                      ItemStringFormat="hh\:mm" 
                      Margin="0,0,15,0" Width="100"/>

            <ComboBox ItemsSource="{Binding TimeSlots}" 
                      SelectedItem="{Binding EndTime}" 
                      ItemStringFormat="hh\:mm" 
                      Width="100"/>
        </StackPanel>

        <Label Content="Køretøj&#xA;" HorizontalAlignment="Center" Margin="0,296,0,0" VerticalAlignment="Top"/>

        <Button x:Name="BookCarButton" Content="Bil" HorizontalAlignment="Left" Margin="257,339,0,0" VerticalAlignment="Top" Height="54" Width="107" Click="BookCarClick"/>
        <Button x:Name="BookBikeButton" Content="Cykel" HorizontalAlignment="Left" Margin="430,339,0,0" VerticalAlignment="Top" Height="54" Width="107" Click="BookBikeClick"/>
    </Grid>
</Window>