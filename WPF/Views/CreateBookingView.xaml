<Window x:Class="WPF.CreateBookingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        xmlns:models="clr-namespace:App.Models;assembly=App"
        mc:Ignorable="d"
        Title="Opret Tilpasset Booking" Height="480" Width="700" Background="#F8FAFC">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="40,30,40,15">
            <TextBlock Text="Planlagt reservation" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Konfigurer dine detaljer og vælg det ønskede køretøj nedenfor." FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="40,0,40,40">
            <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="30,25">
                <StackPanel VerticalAlignment="Center">
                    
                    <TextBlock Text="1. Vælg dato og tidsrum" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/> <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Dato" FontSize="12" FontWeight="Medium" Foreground="#64748B" Margin="0,0,0,6"/>
                            <DatePicker DisplayDateStart="{Binding MinDate, Mode=OneTime}" 
                                        DisplayDateEnd="{Binding MaxDate, Mode=OneTime}" 
                                        SelectedDate="{Binding Date, UpdateSourceTrigger=PropertyChanged}" 
                                        Height="35" Padding="5,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Fra" FontSize="12" FontWeight="Medium" Foreground="#64748B" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding TimeSlots}" 
                                      SelectedItem="{Binding StartTime}" 
                                      ItemStringFormat="hh\:mm" 
                                      Height="35" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Til" FontSize="12" FontWeight="Medium" Foreground="#64748B" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding TimeSlots}" 
                                      SelectedItem="{Binding EndTime}" 
                                      ItemStringFormat="hh\:mm" 
                                      Height="35" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#F1F5F9" Margin="0,0,0,25"/>

                    <TextBlock Text="2. Vælg køretøj for at gennemføre" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,12"/>
                    
                    <UniformGrid Columns="2" Rows="1" Height="50">
                        <Button Content="Bekræft &amp; Book Bil" 
                                Command="{Binding RegisterBookingCommand}"
                                CommandParameter="{x:Static models:VehicleTypes.Car}"
                                FontSize="15" FontWeight="SemiBold"
                                Background="#2563EB" Foreground="White" BorderThickness="0"
                                Margin="0,0,8,0"/>

                        <Button Content="Bekræft &amp; Book Cykel" 
                                Command="{Binding RegisterBookingCommand}"
                                CommandParameter="{x:Static models:VehicleTypes.Bike}"
                                FontSize="15" FontWeight="SemiBold"
                                Background="#2563EB" Foreground="White" BorderThickness="0"
                                Margin="8,0,0,0"/>
                    </UniformGrid>

                </StackPanel>
            </Border>
        </Grid>
        <Popup x:Name="NotificationBox" 
                   IsOpen="True" 
                   AllowsTransparency="True" 
                   StaysOpen="True" 
                   PopupAnimation="Fade"
                   PlacementTarget="{Binding ElementName=ParentGrid}"
                   Placement="Right" 
                   HorizontalOffset="-210" 
                   VerticalOffset="20">

            <Border Background="#1E293B" CornerRadius="12" Padding="20,15" Width="200">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="2"/>
                </Border.Effect>

                <StackPanel Orientation="Horizontal">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>