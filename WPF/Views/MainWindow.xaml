    <Window x:Class="WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="Køretøjsbooking" Height="500" Width="850" Background="#F8FAFC">

    <Grid x:Name="ParentGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="40,35,40,20">
            <TextBlock Text="Køretøjsbooking" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Lokation: Tulipanvej 100" FontSize="16" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="40,0,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Hurtig-booking" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock FontSize="14" Foreground="#64748B" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20">
                        Skal du afsted med det samme? Book et ledigt køretøj i <Run FontWeight="Bold">2 timer</Run> med ét enkelt klik.
                        </TextBlock>
                    </StackPanel>

                    <UniformGrid Grid.Row="2" Columns="2" Rows="1" Height="60">
                        <Button x:Name="LynBookingCar" Content="{Binding BookCarLabel}" Command="{Binding BookCarCommand}" 
                                FontSize="16" FontWeight="SemiBold" Background="#10B981" Foreground="White" BorderThickness="0" Margin="0,0,6,0"/>

                        <Button x:Name="LynBookingCykel" Content="{Binding BookBikeLabel}" Command="{Binding BookBikeCommand}" 
                                FontSize="16" FontWeight="SemiBold" Background="#10B981" Foreground="White" BorderThickness="0" Margin="6,0,0,0"/>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Planlagt reservation" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Skal du bruge et køretøj senere, i længere tid, eller har du specifikke krav? Skræddersy din booking her." 
                                   FontSize="14" Foreground="#64748B" TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20"/>
                    </StackPanel>

                    <Button Grid.Row="2" Content="Opret tilpasset booking" Command="{Binding OpenCreateBookingCommand}" 
                            Height="60" FontSize="16" FontWeight="SemiBold" Background="#2563EB" Foreground="White" BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid> 
            <Popup x:Name="NotificationBox" 
                   IsOpen="True" 
                   AllowsTransparency="True" 
                   StaysOpen="True" 
                   PopupAnimation="Fade"
                   PlacementTarget="{Binding ElementName=ParentGrid}"
                   Placement="Right" 
                   HorizontalOffset="-210" 
                   VerticalOffset="20">

                <Border Background="#1E293B" CornerRadius="12" Padding="20,15" Width="200">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="2"/>
                    </Border.Effect>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
        </Popup>
    </Grid>
</Window>