<Window x:Class="WPF.CreateBookingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="CreateBookingView" Height="450" Width="800">
    <Grid>
        <Label Content="Start" HorizontalAlignment="Left" Margin="330,177,0,0" VerticalAlignment="Top"/>
        <Label Content="Opret Booking&#xD;&#xA;" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="33" Width="127"/>
        <DatePicker x:Name="BookingDatePicker" HorizontalAlignment="Center" Margin="0,81,0,0" VerticalAlignment="Top" SelectedDateChanged="BookingDatePicker_SelectedDateChanged"/>
        <Button x:Name="BookCarButton" Content="Bil" HorizontalAlignment="Left" Margin="257,339,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.363,-2.646" Height="54" Width="107" Click="BookCarClick"/>
        <Label Content="Dato&#xA;" HorizontalAlignment="Center" Margin="0,39,0,0" VerticalAlignment="Top"/>
        <Label Content="Køretøj&#xA;" HorizontalAlignment="Center" Margin="0,296,0,0" VerticalAlignment="Top"/>
        <Button x:Name="BookBikeButton" Content="Cykel" HorizontalAlignment="Left" Margin="430,339,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.363,-2.646" Height="54" Width="107" Click="BookBikeClick"/>
        <Label Content="Tidspunkt&#xA;" HorizontalAlignment="Center" Margin="0,130,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="StartTimeComboBox" HorizontalAlignment="Left" Margin="386,179,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="StartTimeComboBox_SelectionChanged"/>
        <Label Content="Slut" HorizontalAlignment="Left" Margin="330,208,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="EndTimeComboBox" HorizontalAlignment="Left" Margin="386,210,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="EndTimeComboBox_SelectionChanged"/>

    </Grid>
</Window>
